{
  "_comment": "Secrets live in workspace .credentials/*.env (see references/credentials.md). Do not put api_key/token/session here.",
  "moviepilot": {
    "base_url": "http://127.0.0.1:3002",
    "mcporter_server": "moviepilot"
  },
  "nextfind": {
    "base_url": "http://127.0.0.1:8092",
    "prefix": "/api/openapi",
    "timeout": 45
  },
  "telegram_music": {
    "bot": "@your_music_bot",
    "download_dir": "./downloads/music",
    "button_index": 1,
    "search_timeout": 20,
    "download_timeout": 30,
    "poll_interval": 1
  },
  "douyin": {
    "api_base_url": "http://127.0.0.1:7899",
    "download_dir": "./downloads/douyin",
    "timeout": 60
  },
  "bilibili": {
    "api_base_url": "http://127.0.0.1:7899",
    "download_dir": "./downloads/bilibili",
    "quality": 80,
    "timeout": 120
  },
  "playlist": {
    "proxy": null,
    "timeout": 30,
    "default_limit": null
  },
  "hongguo": {
    "proxy": null,
    "timeout": 30,
    "download_dir": "./downloads/hongguo"
  },
  "clouddrive": {
    "url": "http://127.0.0.1:19798",
    "default_folder": "/cloud/download/staging",
    "timeout": 30,
    "insecure": true,
    "save_paths": [
      {
        "path": "/cloud/download/staging",
        "label": "staging",
        "aliases": ["staging", "download", "default", "中转"]
      },
      {
        "path": "/cloud/download/other",
        "label": "other",
        "aliases": ["other", "else", "其他"]
      }
    ]
  }
}
