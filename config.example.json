{
  "_comment": "Copy to config.json (gitignored). Put secrets in workspace .credentials/*.env — see references/credentials.md and INSTALL.md.",
  "moviepilot": {
    "base_url": "http://127.0.0.1:3000",
    "mcporter_server": "moviepilot"
  },
  "nextfind": {
    "base_url": "http://127.0.0.1:PORT",
    "prefix": "/api/openapi",
    "timeout": 45
  },
  "telegram_music": {
    "bot": "@your_music_bot",
    "download_dir": "./downloads/music",
    "button_index": 1,
    "search_timeout": 20,
    "download_timeout": 30,
    "poll_interval": 1
  },
  "douyin": {
    "_comment": "Douyin_TikTok_Download_API root URL (see project README for port mapping)",
    "api_base_url": "http://127.0.0.1:PORT",
    "download_dir": "./downloads/douyin",
    "timeout": 60
  },
  "bilibili": {
    "_comment": "Usually the same Douyin_TikTok_Download_API instance",
    "api_base_url": "http://127.0.0.1:PORT",
    "download_dir": "./downloads/bilibili",
    "quality": 80,
    "timeout": 120
  },
  "playlist": {
    "proxy": null,
    "timeout": 30,
    "default_limit": null
  },
  "hongguo": {
    "proxy": null,
    "timeout": 30,
    "download_dir": "./downloads/hongguo"
  },
  "clouddrive": {
    "url": "http://127.0.0.1:PORT",
    "default_folder": "/cloud/download/staging",
    "timeout": 30,
    "insecure": true,
    "save_paths": [
      {
        "path": "/cloud/download/staging",
        "label": "staging",
        "aliases": ["staging", "download", "default"]
      },
      {
        "path": "/cloud/download/other",
        "label": "other",
        "aliases": ["other"]
      }
    ]
  }
}
