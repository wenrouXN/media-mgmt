{
  "id": "tiktok",
  "name": "TikTok (Douyin_TikTok_Download_API)",
  "kind": "content_api",
  "description": "TikTok endpoints on Douyin_TikTok_Download_API (same host as douyin/hybrid, default :7899)",
  "config_section": "douyin",
  "required_config": [
    "api_base_url"
  ],
  "ops": [
    "health",
    "capabilities",
    "intent",
    "parse",
    "api",
    "video",
    "video_app",
    "comments",
    "comment_replies",
    "user_profile",
    "user_posts",
    "user_likes",
    "user_fans",
    "user_follow",
    "hybrid_video",
    "download"
  ],
  "health": {
    "type": "http_get",
    "url_from": "config.api_base_url",
    "ok_status": [
      200,
      404
    ]
  }
}
